# Supabase Configuration Template
# Copy this file to .env.local and fill in your Supabase Project credentials

# The API URL of your Supabase project (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# The anon/public API key of your Supabase project (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
